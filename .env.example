# ─────────────────────────────────────────────────────────────────
# TAJ TECHNOLOGIE — ERP/CRM
# Copiez ce fichier en .env et remplissez toutes les valeurs
# ─────────────────────────────────────────────────────────────────

# ── Environnement ─────────────────────────────────────────────────
NODE_ENV=production

# ── Base de données PostgreSQL ────────────────────────────────────
DB_USERNAME=taj_user
DB_PASSWORD=change_me_db
DB_NAME=taj_erp
# DB_SYNCHRONIZE=false   # true uniquement en développement (dangereux en prod)

# ── Redis ─────────────────────────────────────────────────────────
REDIS_PASSWORD=change_me_redis   # laisser vide pour désactiver l'auth

# ── JWT ───────────────────────────────────────────────────────────
# Générer avec : openssl rand -hex 64
JWT_SECRET=CHANGE_ME_jwt_secret_at_least_64_chars_long
JWT_ACCESS_EXPIRY=15m

JWT_REFRESH_SECRET=CHANGE_ME_refresh_secret_different_from_jwt_secret
JWT_REFRESH_EXPIRY=7d

# ── CORS ──────────────────────────────────────────────────────────
# Liste des origines autorisées (séparées par des virgules)
CORS_ORIGINS=http://localhost:3000,https://your-domain.com

# ── Application ───────────────────────────────────────────────────
APP_URL=http://localhost
# En production : APP_URL=https://your-domain.com
